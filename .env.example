NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Optional: websocket/API origin when same-origin Vercel rewrites are used.
NEXT_PUBLIC_BACKEND_ORIGIN=http://127.0.0.1:8000
# --- Vercel production (typical) ---
# HTTP `/api/*` proxies to Render via `vercel.json` rewrites → leave API base empty:
#   (do not set NEXT_PUBLIC_API_BASE_URL)
#
# WebSockets bypass Vercel → browser connects directly to FastAPI:

NEXT_PUBLIC_BACKEND_ORIGIN=https://zomate-fitness-system-back.onrender.com

# --- Optional: browser calls FastAPI directly for everything (HTTP + WS).
# Requires backend CORS (see Render env `CORS_ALLOWED_ORIGINS`).
# NEXT_PUBLIC_API_BASE_URL=https://zomate-fitness-system-back.onrender.com

# --- Local dev ---
# NEXT_PUBLIC_BACKEND_ORIGIN=http://127.0.0.1:8000

# --- Next mock routes only ---
# NEXT_PUBLIC_USE_NEXT_MOCK_API=1
